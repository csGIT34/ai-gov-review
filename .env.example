# ---------------------------------------------------------------------------
# AI Governance Review — example environment.
# Copy to `.env` for local dev. NEVER commit a real .env or any cloud keys.
# ---------------------------------------------------------------------------

APP_ENV=local
LOG_LEVEL=INFO

# Postgres (docker-compose service name `db`)
POSTGRES_USER=aigov
POSTGRES_PASSWORD=changeme-local-only
POSTGRES_DB=aigov
DATABASE_URL=postgresql+psycopg://aigov:changeme-local-only@db:5432/aigov

# API
API_CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# Dev auth (M0–M4 only). Replaced by OIDC in M10.
# When true, the API trusts X-Dev-User / X-Dev-Roles headers and seeds dev users.
DEV_AUTH_ENABLED=true

# --- Cloud discovery (wired in M5/M6; keyless in prod — do NOT paste keys) ---
# Azure: DefaultAzureCredential resolves a managed identity in prod.
# AZURE_TENANT_ID=
# GCP: Application Default Credentials resolve an attached service account.
# GOOGLE_CLOUD_PROJECT=
